meta {
  name: Sync User
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/v1/auth/sync
  body: json
  auth: bearer
}

auth:bearer {
  token: {{firebaseToken}}
}

body:json {
  {
    "firebase_uid": "{{testUid}}",
    "email": "test@example.com",
    "role": "student",
    "display_name": "Test Student"
  }
}

assert {
  res.status: eq 200
  res.body.success: eq true
  res.body.data.email: eq test@example.com
}
