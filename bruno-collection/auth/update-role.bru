meta {
  name: Update Role
  type: http
  seq: 3
}

put {
  url: {{baseUrl}}/api/v1/auth/role
  body: json
  auth: bearer
}

auth:bearer {
  token: {{firebaseToken}}
}

body:json {
  {
    "role": "recruiter"
  }
}

assert {
  res.status: eq 200
  res.body.success: eq true
  res.body.data.role: eq recruiter
}
