meta {
  name: Update My Profile
  type: http
  seq: 2
}

patch {
  url: {{baseUrl}}/api/v1/profile/me
  body: json
  auth: bearer
}

auth:bearer {
  token: {{firebaseToken}}
}

body:json {
  {
    "display_name": "Tejas M",
    "bio": "Full-stack dev and AI enthusiast",
    "skills": ["Python", "React", "FastAPI"],
    "domain": "Software Engineering",
    "location": "India",
    "is_public": true
  }
}
